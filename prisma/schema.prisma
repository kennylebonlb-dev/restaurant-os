generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
  STAFF
}

enum TableZone {
  INDOOR
  TERRACE
  VIP
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TableBlockReason {
  MAINTENANCE
  ADMIN
  EVENT
}

model User {
  id            String        @id @default(cuid())
  name          String?
  firstName     String?
  lastName      String?
  email         String        @unique
  contactEmail  String?
  phone         String?
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role          @default(CLIENT)
  accounts      Account[]
  sessions      Session[]
  restaurants   Restaurant[]  @relation("RestaurantOwner")
  reservations  Reservation[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Restaurant {
  id           String        @id @default(cuid())
  ownerId      String?
  owner        User?         @relation("RestaurantOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  name         String
  slug         String        @unique
  description  String?
  address      String?
  phone        String?
  timezone     String        @default("Europe/Paris")
  openingHours Json
  settings     Json          @default("{}")
  menu         Json          @default("[]")
  imageKey     String?
  layoutLocked Boolean       @default(false)
  tables       Table[]
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([ownerId])
  @@map("restaurants")
}

model Table {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  label        String
  capacity     Int
  zone         TableZone     @default(INDOOR)
  positionX    Float         @default(120)
  positionY    Float         @default(120)
  rotation     Float         @default(0)
  active       Boolean       @default(true)
  reservations Reservation[]
  blocks       TableBlock[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([restaurantId, label])
  @@index([restaurantId, active, capacity])
  @@map("tables")
}

model Reservation {
  id             String            @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  tableId        String?
  table          Table?            @relation(fields: [tableId], references: [id], onDelete: SetNull)
  guestFirstName String?
  guestLastName  String?
  guestEmail     String?
  guestPhone     String?
  date           DateTime          @db.Date
  startTime      String            @db.VarChar(5)
  endTime        String            @db.VarChar(5)
  numberOfGuests Int
  status         ReservationStatus @default(PENDING)
  notes          String?
  highChair      Boolean           @default(false)
  birthday       Boolean           @default(false)
  romanticDinner Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([restaurantId, date])
  @@index([tableId, date, startTime, endTime])
  @@index([userId, date])
  @@map("reservations")
}

model TableBlock {
  id                String           @id @default(cuid())
  tableId           String
  table             Table            @relation(fields: [tableId], references: [id], onDelete: Cascade)
  date              DateTime         @db.Date
  startTime         String           @db.VarChar(5)
  endTime           String           @db.VarChar(5)
  reason            TableBlockReason
  customerFirstName String?
  customerLastName  String?
  customerEmail     String?
  customerPhone     String?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([tableId, date, startTime, endTime])
  @@map("table_blocks")
}
